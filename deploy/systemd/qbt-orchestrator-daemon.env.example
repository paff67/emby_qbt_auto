QBT_ORCH_CONFIG=/etc/qbt-orchestrator/config.json
QBT_ORCH_STATE_DB=/var/lib/qbt-orchestrator/state.sqlite
QBT_ORCH_DRY_RUN=1
QBT_ORCH_BACKGROUND_EVENT_WORKERS=0
QBT_ORCH_EVENT_WORKER_INTERVAL_SEC=1
QBT_ORCH_EVENT_WORKER_JOIN_TIMEOUT_SEC=0.2
QBT_ORCH_PLANNER_DRY_RUN=1
# Scheduler-v3 staged rollout. Start legacy, then shadow, then live.
QBT_ORCH_SCHEDULER_ENGINE=legacy
# Reserved rollout markers: schema/data are additive and these do not imply a
# downgrade path. Keep 0 until the corresponding rollout stage is approved.
QBT_ORCH_RESOURCE_LEDGER_V2=0
QBT_ORCH_BATCH_LEASES_V2=0
QBT_ORCH_UPLOAD_PHASES_V2=0
QBT_ORCH_CAPACITY_DEADLOCK_ALERTS=1
QBT_ORCH_ACTIVE_SLOTS=5
QBT_ORCH_SLOW_ACTIVE_DEMOTE_SEC=180
QBT_ORCH_FINISH_RESIDENT_MAX_REMAINING_MB=256
QBT_ORCH_DISK_FLOOR_GB=2
QBT_ORCH_EMERGENCY_FLOOR_GB=1.5
QBT_ORCH_RECOVERY_MODE=1
QBT_ORCH_RECOVERY_ENTER_GB=2.5
QBT_ORCH_RECOVERY_ACTIVE_SLOTS=4
QBT_ORCH_RECOVERY_MAX_REMAINING_GB=1.5
QBT_ORCH_RECOVERY_MARGIN_MB=256
QBT_ORCH_SOAK_ENABLED=1
QBT_ORCH_SOAK_DRY_RUN=1
QBT_ORCH_SOAK_RESIDENT_SLOTS=8
QBT_ORCH_SOAK_ALLOWED_MODES=normal,explore
QBT_ORCH_SOAK_REQUIRE_SWARM=1
QBT_ORCH_MAX_COLD_PARTIAL_GB=4
QBT_ORCH_MAX_COLD_PARTIAL_TORRENTS=8
QBT_ORCH_SOAK_MAX_NEW_PER_HOUR=4
# Deprecated compatibility only; soak no longer hard-blocks on this value.
QBT_ORCH_SOAK_MIN_FREE_GB=0
QBT_ORCH_SOAK_MAX_EXPOSURE_GB=4
QBT_ORCH_SOAK_MIN_EXPOSURE_MB=128
QBT_ORCH_SOAK_MAX_PER_TORRENT_EXPOSURE_MB=512
QBT_ORCH_SOAK_EXPOSURE_HORIZON_SEC=900
QBT_ORCH_SOAK_HOT_BPS=1048576
QBT_ORCH_SOAK_LOW_BPS=102400
QBT_ORCH_SOAK_HOT_CONFIRM_SEC=60
QBT_ORCH_SOAK_COOLDOWN_SEC=1800
QBT_ORCH_SOAK_MAX_QBT_ACTIVE_DOWNLOADS=16
QBT_ORCH_SOAK_LOW_CAPACITY_THROTTLE_MARGIN_GB=1
QBT_ORCH_SOAK_LOW_CAPACITY_LIMIT_BPS=262144
QBT_ORCH_SOAK_THROTTLE_TRIGGER_BPS=1048576
QBT_ORCH_FILE_BATCH_DRY_RUN=1
QBT_ORCH_BATCH_PIPELINE=0
QBT_ORCH_BATCH_LIVE_VERIFY=0
QBT_ORCH_BATCH_ALLOW_HASHES=
QBT_ORCH_BATCH_ALLOW_TAG=
QBT_ORCH_BATCH_MAX_LIVE_BATCH_BYTES_GB=0
QBT_ORCH_BATCH_MAX_NEW_PER_TICK=5
QBT_ORCH_BATCH_INVENTORY_LIMIT=8
QBT_ORCH_UPLOAD_DRY_RUN=1
QBT_ORCH_FULL_CLEANUP=0
QBT_ORCH_FULL_CLEANUP_DRY_RUN=1
QBT_ORCH_CLEANUP_MIN_SEED_SEC=900
QBT_ORCH_CLEANUP_MIN_RATIO=1.0
# Default full-speed rclone uploads. Set to 1 only if you want IoGovernor to
# dynamically reduce transfers/checkers and add --bwlimit under disk/iowait pressure.
QBT_ORCH_IO_GOVERNOR_ENABLED=0
QBT_ORCH_MEDIA_PIPELINE_DRY_RUN=1
QBT_ORCH_EMBY_REFRESH_DRY_RUN=1
QBT_ORCH_NOTIFICATION_DRY_RUN=1
QBT_ORCH_SCHEDULER_ALERTS=1
QBT_ORCH_SCHEDULER_ALERT_INTERVAL_SEC=1800
QBT_ORCH_DISK_ALERT_MARGIN_MB=512
# Optional override; default uses QBT_ORCH_TG_ADMINS as private chat IDs.
QBT_ORCH_TG_ALERT_CHAT_IDS=
QBT_ORCH_FILENAME_NORMALIZE=1
QBT_ORCH_FILENAME_NORMALIZE_SCRIPT=/opt/qbt/gdrive-backfill/bin/jav_name_normalize.py
QBT_ORCH_FILENAME_NORMALIZE_TIMEOUT_SEC=30
QBT_ORCH_FILENAME_NORMALIZE_MIN_CONFIDENCE=0.8
QBT_ORCH_MEDIA_ALLOW_UNRECOGNIZED_PASSTHROUGH=1
QBT_ORCH_UPLOAD_BACKPRESSURE_MAX_BACKLOG_GB=20
QBT_ORCH_UPLOAD_BACKPRESSURE_MAX_OLDEST_PENDING_SEC=3600
QBT_ORCH_RETENTION_DAYS=5
QBT_ORCH_RETENTION_DELETE_BATCH_SIZE=1000
QBT_ORCH_SQLITE_JOURNAL_SIZE_LIMIT_BYTES=67108864
QBT_ORCH_PATH_RECONCILE=1
QBT_ORCH_QBT_PREFERENCES_GUARD=1
QBT_ORCH_QBT_PREFERENCES_DRY_RUN=1
QBT_ORCH_QBT_PREALLOCATE_ALL=0
QBT_ORCH_QBT_INCOMPLETE_FILES_EXT=
QBT_ORCH_QBT_API_MODE=docker
QBT_ORCH_QBT_API_BASE=http://127.0.0.1:8081
QBT_ORCH_QBT_API_TIMEOUT_SEC=10
QBT_ORCH_QBT_API_MAX_RPS=4
QBT_ORCH_QBT_AUTH_MODE=required
QBT_ORCH_SYNC_DEGRADED_INTERVAL_SEC=10
QBT_ORCH_SYNC_REPEATED_FULL_LIMIT=3
QBT_ORCH_BACKGROUND_PERIODIC_WORKERS=1
QBT_ORCH_PERIODIC_WORKER_JOIN_TIMEOUT_SEC=5
# API modes:
# - docker: docker exec qbittorrent curl http://127.0.0.1:8080/...
# - host: direct host HTTP API, uses QBT_ORCH_QBT_USERNAME/PASSWORD
# - host-proxy: localhost-only bridge on 127.0.0.1:18081, no qBT SID login
# For host-proxy set:
# QBT_ORCH_QBT_API_MODE=host-proxy
# QBT_ORCH_QBT_API_BASE=http://127.0.0.1:18081
# QBT_ORCH_QBT_HTTP_HOST_HEADER=127.0.0.1:8080
# Host HTTP mode needs qBT WebUI credentials unless qBT trusts the caller IP.
# Set only in /etc/qbt-orchestrator/daemon.env on the VPS, never commit secrets.
# QBT_ORCH_QBT_USERNAME=
# QBT_ORCH_QBT_PASSWORD=
QBT_ORCH_ORPHAN_JANITOR=1
QBT_ORCH_ORPHAN_JANITOR_DRY_RUN=1
QBT_ORCH_ORPHAN_ROOT=/data/downloads/active
QBT_ORCH_ORPHAN_TRASH_DIR=/data/downloads/.orchestrator-trash
QBT_ORCH_ORPHAN_MIN_AGE_SEC=86400
QBT_ORCH_ORPHAN_CONFIRMATIONS=2
QBT_ORCH_JUNK_JANITOR=1
QBT_ORCH_JUNK_JANITOR_DRY_RUN=1
QBT_ORCH_JUNK_ROOT=/data/downloads/active
QBT_ORCH_JUNK_TRASH_DIR=/data/downloads/.orchestrator-trash
QBT_ORCH_JUNK_STABLE_MTIME_SEC=60
QBT_ORCH_JUNK_MAX_AUTO_QUARANTINE_BYTES=10485760
QBT_ORCH_JUNK_ACTIVE_FAST_BPS=2097152
QBT_ORCH_JUNK_FILE_REFRESH_LIMIT=3
QBT_ORCH_OBSERVE_PROMOTION=1
QBT_ORCH_OBSERVE_PROMOTION_DRY_RUN=0
QBT_ORCH_OBSERVE_MIN_MAIN_MB=100
QBT_ORCH_OBSERVE_PROMOTION_LIMIT=50
QBT_ORCH_CAROUSEL=1
QBT_ORCH_CAROUSEL_DRY_RUN=1
QBT_ORCH_CAROUSEL_CONCURRENCY=3
QBT_ORCH_CAROUSEL_PROBE_DURATION_SEC=1800
QBT_ORCH_CAROUSEL_MIN_FREE_GB=5
QBT_ORCH_CAROUSEL_LIVE_VERIFY=0
QBT_ORCH_PREEMPTION=1
QBT_ORCH_PREEMPTION_DRY_RUN=1
QBT_ORCH_PREEMPTION_MIN_NEW_SCORE=75
QBT_ORCH_PREEMPTION_MIN_SEED_SCORE=65
QBT_ORCH_PREEMPTION_SCORE_MARGIN=10
QBT_ORCH_PREEMPTION_MIN_SEED_SEC=900
QBT_ORCH_PREEMPTION_MAX_UPLOAD_BPS=65536
QBT_ORCH_PREEMPTION_MAX_PER_HOUR=3
QBT_ORCH_HOST_DOWNLOADS=/data/downloads
QBT_ORCH_CONTAINER_DOWNLOADS=/downloads
QBT_ORCH_BACKFILL_SCRAPER=0
QBT_ORCH_BACKFILL_SCRIPT=/opt/qbt/gdrive-backfill/bin/javinizer_scrape_one.sh
QBT_ORCH_SIDECAR_STAGING_ROOT=/var/lib/qbt-orchestrator/sidecar-staging
QBT_ORCH_BACKFILL_TIMEOUT_SEC=1020
QBT_ORCH_BACKFILL_LOCK_FILE=/tmp/gdrive-backfill.lock
QBT_ORCH_BACKFILL_COMMAND_MODE=auto
# Telegram bot token/admin IDs are intentionally omitted; set QBT_ORCH_TELEGRAM_TOKEN and QBT_ORCH_TG_ADMINS in /etc/qbt-orchestrator/daemon.env on the VPS only.
EMBY_BASE_URL=http://127.0.0.1:8096
# Emby API key is intentionally omitted; set EMBY_API_KEY in /etc/qbt-orchestrator/daemon.env on the VPS only.
