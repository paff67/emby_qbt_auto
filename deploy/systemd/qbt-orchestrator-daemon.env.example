QBT_ORCH_CONFIG=/etc/qbt-orchestrator/config.json
QBT_ORCH_STATE_DB=/var/lib/qbt-orchestrator/state.sqlite
QBT_ORCH_DRY_RUN=1
QBT_ORCH_BACKGROUND_EVENT_WORKERS=0
QBT_ORCH_EVENT_WORKER_INTERVAL_SEC=1
QBT_ORCH_EVENT_WORKER_JOIN_TIMEOUT_SEC=0.2
QBT_ORCH_PLANNER_DRY_RUN=1
QBT_ORCH_ACTIVE_SLOTS=5
QBT_ORCH_SLOW_ACTIVE_DEMOTE_SEC=180
QBT_ORCH_FILE_BATCH_DRY_RUN=1
QBT_ORCH_BATCH_PIPELINE=0
QBT_ORCH_BATCH_LIVE_VERIFY=0
QBT_ORCH_BATCH_ALLOW_HASHES=
QBT_ORCH_BATCH_ALLOW_TAG=
QBT_ORCH_BATCH_MAX_LIVE_BATCH_BYTES_GB=0
QBT_ORCH_BATCH_MAX_NEW_PER_TICK=5
QBT_ORCH_UPLOAD_DRY_RUN=1
QBT_ORCH_MEDIA_PIPELINE_DRY_RUN=1
QBT_ORCH_EMBY_REFRESH_DRY_RUN=1
QBT_ORCH_NOTIFICATION_DRY_RUN=1
